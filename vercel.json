{
  "version": 2,
  "builds": [
    { "src": "api/server.js", "use": "@vercel/node" },
    { "src": "ui/index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/health", "dest": "api/server.js" },
    { "src": "/workspaces(.*)", "dest": "api/server.js" },
    { "src": "/workspace(.*)", "dest": "api/server.js" },
    { "src": "/waitlist", "dest": "api/server.js" },
    { "src": "/(.*)", "dest": "ui/index.html" }
  ]
}
